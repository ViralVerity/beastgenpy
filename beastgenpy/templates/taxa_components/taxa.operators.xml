<%import core_funcs%>
%for name, info in config["sequence_info"]:
%for sequence in info["taxon_list"]:
<%date,uncertainty= core_funcs.decimal_date(sequence.split("|")[-1])%>\
%if uncertainty == 1.0:	
   		<uniformOperator weight="0.001">
			<parameter idref="age(${sequence})"/>
		</uniformOperator>
%endif
%endfor
%endfor