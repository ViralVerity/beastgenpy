%for name, info in config["sequence_info"]:
	<alignment id="${name}.alignment" dataType="nucleotide">
%for sequence in info["sequences"]:
		<sequence>
            <taxon idref="${sequence.id}"/>
            ${sequence.seq}
        </sequence>
%endfor
	</alignment>

	<patterns id="${name}.patterns" from="1" strip="false">
		<alignment idref="${name}.alignment"/>
	</patterns>
%endfor
