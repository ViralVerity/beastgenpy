<?xml version="1.0" standalone="yes"?>
<%
	    import core_funcs
%> 
<!--generated with beastgen.py-->

<beast>
   <!-- The list of taxa to be analysed (can also include dates/ages).          -->
%for taxon_info in config["fasta"]:
<%name = taxon_info["name"]
taxa_list = taxon_info["sequences"]%>\
    <!-- ntax=${len(taxa_list)}                                             -->
    <taxa id="taxa_${name}">
%for sequence in taxa_list: 
        <taxon id="${sequence.id}">
<% date,uncertainty= core_funcs.decimal_date(sequence.id.split("|")[-1])%>\
            <date value="${date}" direction="forwards" units="years" uncertainty="${uncertainty}"/> 
%for trait in config["traits"]:
            <attr name="${trait}">
                ${config["trait_dict"][sequence.id][trait]}
            </attr>
%endfor
        </taxon>
%endfor 
    </taxa> 
%endfor

%if not config["fixed_tree"]:
%for taxon_info in config["fasta"]:
	<%name = taxon_info["name"]%>
	<alignment id="alignment_${name}" dataType="nucleotide">
%for sequence in taxon_info["sequences"]:
		<sequence>
            <taxon idref="${sequence.id}"/>
            ${sequence.seq}
        </sequence>
%endfor
	</alignment>

	<patterns id="patterns_${name}" from="1" strip="false">
		<alignment idref="alignment_${name}"/>
	</patterns>
%endfor
%endif

%if config["fixed_tree"]:
<!-- Insert fixed tree blocks -->  
%for tree_name, tree_file in config["tree_file_dict"].items():
	<empiricalTreeDistributionModel id="${tree_name}" fileName="${tree_file}">
		<taxa idref="taxa_${tree_name}"/>
	</empiricalTreeDistributionModel> 
%endfor
%endif

%if not config['fixed_tree'] and not config['starting_tree']:
	<constantSize id="initialDemo" units="years">
		<populationSize>
			<parameter id="initialDemo.popSize" value="100.0"/>
		</populationSize>
	</constantSize>
%for taxon_info in config["fasta"]:
<%name = taxon_info["name"]%>
	<!-- Generate a random starting tree under the coalescent process            -->
	<coalescentSimulator id="startingTree_${name}">
		<taxa idref="taxa_${name}"/>
		<constantSize idref="initialDemo"/>
	</coalescentSimulator>
	
	<treeModel id="treeModel_${name}">
		<coalescentTree idref="startingTree_${name}"/>
		<rootHeight>
			<parameter id="treeModel_${name}.rootHeight"/>
		</rootHeight>
		<nodeHeights internalNodes="true">
			<parameter id="treeModel_${name}.internalNodeHeights"/>
		</nodeHeights>
		<nodeHeights internalNodes="true" rootNode="true">
			<parameter id="treeModel_${name}.allInternalNodeHeights"/>
		</nodeHeights>
<%taxa_list = taxon_info["sequences"]%>
%for sequence in taxa_list:
<%date,uncertainty= core_funcs.decimal_date(sequence.id.split("|")[-1])%>\
%if uncertainty == 1.0:	
		<leafHeight taxon="${sequence.id}">
			<parameter id="age(${sequence.id})"/>
		</leafHeight>
%endif
%endfor

	</treeModel>

	<!-- Statistic for height of the root of the tree                            -->
	<treeHeightStatistic id="rootHeight_${name}">
		<treeModel idref="treeModel_${name}"/>
	</treeHeightStatistic>

	<!-- Statistic for time of most recent common ancestor of tree               -->
	<tmrcaStatistic id="age(root)_${name}" absolute="true">
		<treeModel idref="treeModel_${name}"/>
	</tmrcaStatistic>
	<!-- Statistic for sum of the branch lengths of the tree (tree length)       -->
	<treeLengthStatistic id="treeLength_${name}">
		<treeModel idref="treeModel_${name}"/>
	</treeLengthStatistic>

%endfor
%endif

%if not config["fixed_tree"]:
%for taxon_info in config["fasta"]:
%if config["growth_model"] == "skygrid":
<%name = taxon_info["name"]%>
	<!-- Generate a gmrfSkyGridLikelihood for the Bayesian SkyGrid process       -->
	<gmrfSkyGridLikelihood id="skygrid_${name}">
		<populationSizes>
			<!-- skygrid.logPopSize is in log units unlike other popSize                 -->
			<parameter id="skygrid_${name}.logPopSize" dimension="${config['gridpoints']}" value="1.0"/>
		</populationSizes>
		<precisionParameter>
			<parameter id="skygrid_${name}.precision" value="0.1" lower="0.0"/>
		</precisionParameter>
		<numGridPoints>
			<parameter id="skygrid_${name}.numGridPoints" value="${config['gridpoints']-1}.0"/>
		</numGridPoints>
		<cutOff>
			<parameter id="skygrid_${name}.cutOff" value="${config['cutoff']}"/>
		</cutOff>
		<populationTree>
			<treeModel idref="treeModel_${name}"/>
		</populationTree>
	</gmrfSkyGridLikelihood>

	<gmrfSkyrideGradient id="gmrfGradientPop_${name}" wrtParameter="logPopulationSizes">
		<gmrfSkyGridLikelihood idref="skygrid_${name}"/>
	</gmrfSkyrideGradient>
	
	<compoundParameter id="skygrid_${name}.parameters">
		<parameter idref="skygrid_${name}.precision"/>
		<parameter idref="skygrid_${name}.logPopSize"/>
	</compoundParameter>
	
	<gmrfSkyrideGradient id="gmrfGradientPrec_${name}" wrtParameter="precision">
		<gmrfSkyGridLikelihood idref="skygrid_${name}"/>
	</gmrfSkyrideGradient>
	
	<gammaPrior id="skygrid_${name}.precision.prior" shape="0.001" scale="1000" offset="0.0">
		<parameter idref="skygrid_${name}.precision"/>
	</gammaPrior>
	
	<jointGradient id="joint.skygrid_${name}.precision">
		<gmrfSkyrideGradient idref="gmrfGradientPrec_${name}"/>
		<gradient>
			<gammaPrior idref="skygrid_${name}.precision.prior"/>
			<parameter idref="skygrid_${name}.precision"/>
		</gradient>
	</jointGradient>
	
	<compoundGradient id="full.skygrid_${name}.gradient">
		<jointGradient idref="joint.skygrid_${name}.precision"/>
		<gmrfSkyrideGradient idref="gmrfGradientPop_${name}"/>
	</compoundGradient>
%endif
%if config["clock_model"] == "relaxed":
    <discretizedBranchRates id="branchRates_${name}">
		<treeModel idref="treeModel_${name}"/>
		<distribution>
			<logNormalDistributionModel meanInRealSpace="true">
				<mean>
					<parameter id="ucld.mean_${name}" value="1.0" lower="0.0"/>
				</mean>
				<stdev>
					<parameter id="ucld.stdev_${name}" value="0.3333333333333333" lower="0.0"/>
				</stdev>
			</logNormalDistributionModel>
		</distribution>
		<rateCategories>
			<parameter id="branchRates.categories_${name}"/>
		</rateCategories>
	</discretizedBranchRates>
	<rateStatistic id="meanRate_${name}" name="meanRate_${name}" mode="mean" internal="true" external="true">
		<treeModel idref="treeModel_${name}"/>
		<discretizedBranchRates idref="branchRates_${name}"/>
	</rateStatistic>
	<rateStatistic id="coefficientOfVariation_${name}" name="coefficientOfVariation" mode="coefficientOfVariation" internal="true" external="true">
		<treeModel idref="treeModel_${name}"/>
		<discretizedBranchRates idref="branchRates_${name}"/>
	</rateStatistic>
	<rateCovarianceStatistic id="covariance_${name}" name="covariance">
		<treeModel idref="treeModel_${name}"/>
		<discretizedBranchRates idref="branchRates_${name}"/>
	</rateCovarianceStatistic>
%else:
	<!-- The strict clock (Uniform rates across branches)                        -->
	<strictClockBranchRates id="${name}.branchRates">
		<rate>
			<parameter id="${name}.clock.rate" value="0.001" lower="0.0"/>
		</rate>
	</strictClockBranchRates>
	
	<rateStatistic id="${name}.meanRate" name="${name}.meanRate" mode="mean" internal="true" external="true">
		<treeModel idref="treeModel_${name}"/>
		<strictClockBranchRates idref="${name}.branchRates"/>
	</rateStatistic>
%endif
%endfor
	<gtrModel id="gtr">
		<frequencies>
			<frequencyModel dataType="nucleotide">
				<frequencies>
					<parameter id="frequencies" value="0.25 0.25 0.25 0.25"/>
				</frequencies>
			</frequencyModel>
		</frequencies>
		<rates>
			<parameter id="gtr.rates" dimension="6" value="1.0" lower="0.0"/>
		</rates>
	</gtrModel>
	<siteModel id="siteModel">
		<substitutionModel>
			<gtrModel idref="gtr"/>
		</substitutionModel>
		<gammaShape gammaCategories="4">
			<parameter id="alpha" value="0.5" lower="0.0"/>
		</gammaShape>
	</siteModel>
	<statistic id="mu" name="mu">
		<siteModel idref="siteModel"/>
	</statistic>

%for taxon_info in config["fasta"]:
<%name = taxon_info["name"]%>\
	<treeLikelihood id="treeLikelihood_${name}" useAmbiguities="false">
		<patterns idref="patterns_${name}"/>
		<treeModel idref="treeModel_${name}"/>
		<siteModel idref="siteModel"/>
%if config["clock_model"] == "relaxed":
		<discretizedBranchRates idref="branchRates_${name}"/>
%else:
		<strictClockBranchRates idref="${name}.branchRates"/>
%endif
	</treeLikelihood>
%endfor
%endif


<!-- START Multivariate diffusion model                                      -->
	<multivariateDiffusionModel id="${config["overall_trait"]}.diffusionModel">
		<precisionMatrix>
			<matrixParameter id="${config["overall_trait"]}.precision">
				<parameter id="${config["overall_trait"]}.precision.col1" value="0.05 0.002"/>
				<parameter id="${config["overall_trait"]}.precision.col2" value="0.002 0.05"/>
			</matrixParameter>
		</precisionMatrix>
	</multivariateDiffusionModel>

	<multivariateWishartPrior id="${config["overall_trait"]}.precisionPrior" df="2">
		<scaleMatrix>
			<matrixParameter>
				<parameter value="1.0 0.0"/>
				<parameter value="0.0 1.0"/>
			</matrixParameter>
		</scaleMatrix>
		<data>
			<parameter idref="${config["overall_trait"]}.precision"/>
		</data>
	</multivariateWishartPrior>

	<!-- END Multivariate diffusion model                                        -->
%for taxon_info in config["fasta"]:
<%name = taxon_info["name"]%>
<!-- START Multivariate diffusion model                                     -->
	<discretizedBranchRates id="${config["overall_trait"]}.diffusionRates_${name}">
		<treeModel idref="treeModel_${name}"/>
		<distribution>
			<onePGammaDistributionModel>
				<shape>
					<!-- half DF (i.e., df = 1)                                                  -->
					<parameter value="0.5"/>
				</shape>
			</onePGammaDistributionModel>
		</distribution>
		<rateCategories>
			<parameter id="${config["overall_trait"]}.rrwCategories_${name}"/>
		</rateCategories>
	</discretizedBranchRates>
	
	<multivariateTraitLikelihood id="${config["overall_trait"]}.traitLikelihood_${name}" traitName="${config["overall_trait"]}" useTreeLength="true" scaleByTime="true" reportAsMultivariate="true" reciprocalRates="true" integrateInternalTraits="true">
		<multivariateDiffusionModel idref="${config["overall_trait"]}.diffusionModel"/>
		<treeModel idref="treeModel_${name}"/>
		<traitParameter>
			<parameter id="leaf.${config["overall_trait"]}_${name}"/>
		</traitParameter>
		<conjugateRootPrior>
			<meanParameter>
				<parameter value="0.0 0.0"/>
			</meanParameter>
			<priorSampleSize>
				<parameter value="0.001"/>
			</priorSampleSize>
		</conjugateRootPrior>
		<discretizedBranchRates idref="${config["overall_trait"]}.diffusionRates_${name}"/>
	</multivariateTraitLikelihood>
	
	<continuousDiffusionStatistic id="${config["overall_trait"]}.diffusionRate_${name}" greatCircleDistance="true">
		<multivariateTraitLikelihood idref="${config["overall_trait"]}.traitLikelihood_${name}"/>
	</continuousDiffusionStatistic>
%endfor
	
	
	<correlation id="${config["overall_trait"]}.correlation" dimension1="1" dimension2="2">
		<matrixParameter idref="${config["overall_trait"]}.precision"/>
	</correlation>
	<matrixInverse id="${config["overall_trait"]}.varCovar">
		<matrixParameter idref="${config["overall_trait"]}.precision"/>
	</matrixInverse>
	

	<!-- END Multivariate diffusion model                                        -->	
	
%for taxon in config["uncertain_polygons"]:
<%name=config["seq_to_tree"][taxon]%>\
	<leafTraitParameter id="${taxon}.trait" taxon="${taxon}">
		<treeModel idref="treeModel_${name}"/>
		<parameter idref="leaf.${config["overall_trait"]}_${name}"/>
	</leafTraitParameter>
	<flatGeoSpatialPrior id="${taxon}_polygons" taxon="${taxon}" kmlFileName="${config['polygon_dir']}/${taxon}.kml" inside="true" union="true" cache="true">
		<data>
			<parameter idref="${taxon}.trait"/>
		</data>
	</flatGeoSpatialPrior>
%endfor

	
	<!-- Define operators                                                        --> 
    <operators id="operators" optimizationSchedule="log">

%if not config["fixed_tree"]:
		<deltaExchange delta="0.01" weight="0.1">
			<parameter idref="gtr.rates"/>
		</deltaExchange>
		<deltaExchange delta="0.01" weight="0.1">
			<parameter idref="frequencies"/>
		</deltaExchange>
		<scaleOperator scaleFactor="0.75" weight="1">
			<parameter idref="alpha"/>
		</scaleOperator>	
%endif  

%for taxon_info in config["fasta"]:
<% name = taxon_info["name"]%>\
%if not config["fixed_tree"]:
		<hamiltonianMonteCarloOperator weight="5" nSteps="50" stepSize="1E-2" mode="vanilla" 
                                        autoOptimize="true" gradientCheckCount="1" gradientCheckTolerance="1E-1" 
                                        preconditioning="none" preconditioningUpdateFrequency="100">
	 		<compoundGradient idref="full.skygrid_${name}.gradient"/>
			<compoundParameter idref="skygrid_${name}.parameters"/>
			<signTransform start="1" end="1">
				<compoundParameter idref="skygrid_${name}.parameters"/>
			</signTransform>
 		</hamiltonianMonteCarloOperator>

%if config["clock_model"] == "relaxed":
		<scaleOperator scaleFactor="0.75" weight="3">
			<parameter idref="ucld.mean_${name}"/>
		</scaleOperator>
		<scaleOperator scaleFactor="0.75" weight="3">
			<parameter idref="ucld.stdev_${name}"/>
		</scaleOperator>
		
		<upDownOperator scaleFactor="0.75" weight="3">
			<up>
				<parameter idref="treeModel_${name}.allInternalNodeHeights"/>
			</up>
			<down>
				<parameter idref="ucld.mean_${name}"/>
			</down>
		</upDownOperator>
		<swapOperator size="1" weight="10" autoOptimize="false">
			<parameter idref="branchRates.categories_${name}"/>
		</swapOperator>
		<uniformIntegerOperator weight="10">
			<parameter idref="branchRates.categories_${name}"/>
		</uniformIntegerOperator>
%else:
		<scaleOperator scaleFactor="0.75" weight="3">
			<parameter idref="${name}.clock.rate"/>
		</scaleOperator>
		<upDownOperator scaleFactor="0.75" weight="3">
			<up>
				<parameter idref="treeModel_${name}.allInternalNodeHeights"/>
			</up>
			<down>
				<parameter idref="${name}.clock.rate"/>
			</down>
		</upDownOperator>
%endif
		
		<uniformOperator weight="9">
			<parameter idref="treeModel_${name}.internalNodeHeights"/>
		</uniformOperator>
		
		<scaleOperator scaleFactor="0.75" weight="3">
			<parameter idref="treeModel_${name}.rootHeight"/>
		</scaleOperator>
		
		<subtreeLeap size="1.0" weight="823">
			<treeModel idref="treeModel_${name}"/>
		</subtreeLeap>
		<fixedHeightSubtreePruneRegraft weight="82.3">
			<treeModel idref="treeModel_${name}"/>
		</fixedHeightSubtreePruneRegraft>
%endif
		<swapOperator size="1" weight="30" autoOptimize="false">
			<parameter idref="${config["overall_trait"]}.rrwCategories_${name}"/>
		</swapOperator>
		<uniformIntegerOperator weight="10">
			<parameter idref="${config["overall_trait"]}.rrwCategories_${name}"/>
		</uniformIntegerOperator>

%for sequence in taxa_list:
<%date,uncertainty= core_funcs.decimal_date(sequence.id.split("|")[-1])%>\
%if uncertainty == 1.0:	
   		<uniformOperator weight="0.001">
			<parameter idref="age(${sequence.id})"/>
		</uniformOperator>
%endif
%endfor
%endfor
		<!-- Insert precisionGibbsOperator blocks --> 
		<precisionGibbsOperator weight="2">
%for taxon_info in config["fasta"]:
<% name = taxon_info["name"]%>
			<multivariateTraitLikelihood idref="${config["overall_trait"]}.traitLikelihood_${name}"/>
%endfor
			<multivariateWishartPrior idref="${config["overall_trait"]}.precisionPrior"/> 
		</precisionGibbsOperator> 

%for taxon in config["uncertain_polygons"]:
		<uniformGeoSpatialOperator weight="0.01">
			<parameter idref="${taxon}.trait"/>
			<flatGeoSpatialPrior idref="${taxon}_polygons"/>
		</uniformGeoSpatialOperator>
%endfor
    </operators>
    
    <mcmc id="mcmc" chainLength="${config["chain_length"]}" autoOptimize="true">
		<joint id="joint">
			<prior id="prior">

%if not config["fixed_tree"]:
				<dirichletPrior alpha="1.0" sumsTo="6.0">
					<parameter idref="gtr.rates"/>
				</dirichletPrior>
				<dirichletPrior alpha="1.0" sumsTo="1.0">
					<parameter idref="frequencies"/>
				</dirichletPrior>
				<exponentialPrior mean="0.5" offset="0.0">
					<parameter idref="alpha"/>
				</exponentialPrior>
%for taxon_info in config["fasta"]:
<% name = taxon_info["name"]%>\
%if config["clock_model"] == "relaxed":
				<exponentialPrior mean="0.3333333333333333" offset="0.0">
					<parameter idref="ucld.stdev_${name}"/>
				</exponentialPrior>
				
				<ctmcScalePrior>
					<ctmcScale>
						<parameter idref="ucld.mean_${name}"/>
					</ctmcScale>
					<treeModel idref="treeModel_${name}"/>
				</ctmcScalePrior>
				<discretizedBranchRates idref="branchRates_${name}"/>
%else:
				<ctmcScalePrior>
					<ctmcScale>
						<parameter idref="${name}.clock.rate"/>
					</ctmcScale>
					<treeModel idref="treeModel_${name}"/>
				</ctmcScalePrior>
				<strictClockBranchRates idref="${name}.branchRates"/>
%endif
				<gammaPrior idref="skygrid_${name}.precision.prior"/>
				<gmrfSkyGridLikelihood idref="skygrid_${name}"/>
				

%endfor
%endif
				<multivariateWishartPrior idref="${config["overall_trait"]}.precisionPrior"/> 

%if config["uncertain_polygons"]:
				<geoDistributionCollection id="allGeoDistributions">
%for taxon in config["uncertain_polygons"]:
					<flatGeoSpatialPrior idref="${taxon}_polygons"/>
%endfor
				</geoDistributionCollection>
%endif
            </prior>

			<likelihood id="likelihood">
%for taxon_info in config["fasta"]:
<% name = taxon_info["name"]%>
				<treeLikelihood idref="treeLikelihood_${name}"/>
				<multivariateTraitLikelihood idref="${config["overall_trait"]}.traitLikelihood_${name}"/>
%endfor
			</likelihood>
		</joint>
        <operators idref="operators"/>

    <!-- write log to screen                                                     -->
		<log id="screenLog" logEvery="${config["log_every"]}">
			<column label="Joint" dp="4" width="12">
				<joint idref="joint"/>
			</column>
			<column label="Prior" dp="4" width="12">
				<prior idref="prior"/>
			</column>
			<column label="Likelihood" dp="4" width="12">
				<likelihood idref="likelihood"/>
			</column>
		</log>

		<log id="fileLog" logEvery="${config["log_every"]}" fileName="${config["file_stem"]}.log" overwrite="false">
			<joint idref="joint"/> 
			<prior idref="prior"/> 
			<likelihood idref="likelihood"/> 
			<!-- START Multivariate diffusion model                                      --> 
			<matrixParameter idref="${config["overall_trait"]}.precision"/> 
			<correlation idref="${config["overall_trait"]}.correlation"/> 
			<matrixInverse idref="${config["overall_trait"]}.varCovar"/> 
%if not config["fixed_tree"]:
			<parameter idref="gtr.rates"/>
			<parameter idref="frequencies"/>
%endif
%for taxon_info in config["fasta"]:
<% name = taxon_info["name"]%>
%if not config['fixed_tree']:
			<parameter idref="treeModel_${name}.rootHeight"/>
			<tmrcaStatistic idref="age(root)_${name}"/>
			<treeLengthStatistic idref="treeLength_${name}"/>
			<parameter idref="skygrid_${name}.precision"/>
			<parameter idref="skygrid_${name}.logPopSize"/>
			<gmrfSkyGridLikelihood idref="skygrid_${name}"/>
%if config["clock_model"] == "relaxed":
			<parameter idref="ucld.mean_${name}"/>
			<parameter idref="ucld.stdev_${name}"/>
			<rateStatistic idref="meanRate_${name}"/>
			<rateStatistic idref="coefficientOfVariation_${name}"/>
			<rateCovarianceStatistic idref="covariance_${name}"/>
%else:
			<parameter idref="${name}.clock.rate"/>
%endif
			<treeLikelihood idref="treeLikelihood_${name}"/>
%endif
			<continuousDiffusionStatistic idref="${config["overall_trait"]}.diffusionRate_${name}"/>
			<multivariateTraitLikelihood idref="${config["overall_trait"]}.traitLikelihood_${name}"/>
%endfor

		</log>

		<!-- write tree log to file                                                  -->
%for taxon_info in config["fasta"]:
<% name = taxon_info["name"]%>
		<logTree id="treeFileLog_${name}" logEvery="${config["log_every"]}" nexusFormat="true" fileName="${name}.trees" sortTranslationTable="true">
			<treeModel idref="treeModel_${name}"/>
			<joint idref="joint"/> 
			<trait name="${config["overall_trait"]}" tag="${config["overall_trait"]}"> 
				<multivariateTraitLikelihood idref="${config["overall_trait"]}.traitLikelihood_${name}"/>
			</trait> 
			<multivariateDiffusionModel idref="${config["overall_trait"]}.diffusionModel"/> 
			<trait name="rate" tag="rate">
%if config["clock_model"] == "relaxed":
				<discretizedBranchRates idref="branchRates_${name}"/>
%else:  
				<strictClockBranchRates idref="${name}.branchRates"/>
%endif
				</trait>
		</logTree> 
%endfor
	</mcmc>

	<report>
		<property name="timer">
			<mcmc idref="mcmc"/>
		</property>
	</report>
	
</beast>
