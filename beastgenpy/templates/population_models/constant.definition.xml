%for name in config["sequence_info"].keys(): 
    <!-- Generate a coalescent likelihood                                        -->
	<coalescentLikelihood id="${name}.coalescent">
		<model>
			<constantSize idref="constant"/>
		</model>
		<intervals>
			<treeIntervals>
				<treeModel idref="${name}.treeModel"/>
			</treeIntervals>
		</intervals>
	</coalescentLikelihood>
%endfor
	