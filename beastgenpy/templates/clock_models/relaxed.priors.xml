                <exponentialPrior mean="0.3333333333333333" offset="0.0">
					<parameter idref="ucld.stdev"/>
				</exponentialPrior>
				
%if len(config["sequence_info"]) > 1:
				<gammaPrior shape="1.0" scale="1.0" offset="0.0">
					<parameter idref="ucld.mean"/>
				</gammaPrior>
%else:
%for name in config["sequence_info"].keys():
				<ctmcScalePrior>
					<ctmcScale>
						<parameter idref="ucld.mean"/>
					</ctmcScale>
					<treeModel idref="${name}.treeModel"/>
				</ctmcScalePrior>
%endfor				
%endif
%for name in config["sequence_info"].keys():
				<discretizedBranchRates idref="${name}.branchRates"/>
%endfor